{
  "name": "armino-dev/binance-connector",
  "description": "Binance API connector for PHP",
  "type": "library",
  "keywords": [
    "binance",
    "binance api",
    "binance connector php"
  ],
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Armino\\BinanceConnector\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Armino\\BinanceConnector\\Tests\\": "tests"
    }
  },
  "authors": [
    {
      "name": "Armino Popp",
      "email": "devel@boioiong.com"
    }
  ],
  "require": {
    "php": ">=7.4|>=8.0",
    "ext-curl": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.65",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "phpunit/phpunit": "^13.0"
  },
  "scripts": {
    "lint": "vendor/bin/parallel-lint --exclude vendor src tests",
    "format": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose",
    "format:check": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose",
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
